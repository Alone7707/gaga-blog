{
  "name": "blog-backend",
  "version": "0.1.0",
  "private": true,
  "description": "开源博客产品后端服务，基于 NestJS + Prisma + SQLite。",
  "license": "MIT",
  "scripts": {
    "env:prepare": "node -e \"const fs=require('fs'); if (!fs.existsSync('.env') && fs.existsSync('.env.example')) { fs.copyFileSync('.env.example', '.env'); console.log('已自动从 .env.example 生成 .env'); } else { console.log('.env 已存在，跳过生成'); }\"",
    "predev": "npm run env:prepare && prisma generate",
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "postinstall": "prisma generate",
    "prisma:generate": "npm run env:prepare && prisma generate",
    "prisma:migrate": "npm run env:prepare && prisma migrate dev",
    "prisma:studio": "npm run env:prepare && prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.3.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.16.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "fastify": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prisma": "^6.16.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
